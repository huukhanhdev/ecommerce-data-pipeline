        toDayOfWeek(full_date)
    )                                             AS day_name,
    arrayElement(
        ['January','February','March','April','May','June','July','August','September','October','November','December'],
        toMonth(full_date)
    )                                             AS month_name,
    toDayOfWeek(full_date) IN (6, 7)              AS is_weekend
FROM date_spine
