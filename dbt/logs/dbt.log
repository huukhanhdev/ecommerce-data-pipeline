        mv_sources.mv_name != ''
      ) as mvs_pointing_to_it,0 as is_on_cluster
        from system.tables as t
      
        join system.databases as db on t.database = db.name
        left join mv_sources on mv_sources.target_fqn = concat(t.database, '.', t.name)
