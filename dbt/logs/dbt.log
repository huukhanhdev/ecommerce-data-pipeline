    FROM `staging_analytics`.`fact_orders`   f
    JOIN `staging_analytics`.`dim_sellers`   s ON f.seller_key  = s.seller_key
    JOIN `staging_analytics`.`dim_products`  p ON f.product_key = p.product_key
    GROUP BY
