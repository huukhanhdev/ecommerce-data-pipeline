  create  table "ecommerce_olap"."staging_analytics"."rpt_daily_revenue__dbt_tmp"
  
  
    as
  
  (
    -- rpt_daily_revenue.sql
-- Daily revenue breakdown by category, status, and payment method



SELECT
    d.full_date,
    d.year,
    d.month,
    d.quarter,
    d.day_name,
    d.is_weekend,
    p.category_name,
    f.status,
    f.payment_method,

    COUNT(DISTINCT f.order_id)          AS total_orders,
    SUM(f.quantity)                     AS total_items_sold,
    SUM(f.total_amount)                 AS gross_revenue,
    SUM(f.shipping_fee)                 AS total_shipping_fees,
    AVG(f.total_amount)                 AS avg_order_value,

    -- 7-day rolling average revenue (window function)
    AVG(SUM(f.total_amount)) OVER (
        PARTITION BY p.category_name
        ORDER BY d.full_date
        ROWS BETWEEN 6 PRECEDING AND CURRENT ROW
    )                                   AS revenue_7d_rolling_avg,

    -- Revenue rank within the week
    RANK() OVER (
        PARTITION BY d.year, d.week_of_year
        ORDER BY SUM(f.total_amount) DESC
    )                                   AS daily_rank_in_week

FROM "ecommerce_olap"."staging_analytics"."fact_orders" f
JOIN "ecommerce_olap"."staging_analytics"."dim_date"     d ON f.date_key    = d.date_key
JOIN "ecommerce_olap"."staging_analytics"."dim_products" p ON f.product_key = p.product_key
WHERE f.status != 'cancelled'
GROUP BY
    d.full_date, d.year, d.month, d.quarter, d.day_name, d.is_weekend,
    d.week_of_year, p.category_name, f.status, f.payment_method
  );
  
