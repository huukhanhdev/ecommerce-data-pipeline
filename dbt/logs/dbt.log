  create  table "ecommerce_olap"."staging_analytics"."dim_date__dbt_tmp"
  
  
    as
  
  (
    -- dim_date.sql (updated: adds week_of_year column for rpt_daily_revenue)



WITH date_spine AS (
    SELECT generate_series(
        '2023-01-01'::date,
        '2027-12-31'::date,
        '1 day'::interval
    )::date AS full_date
)
SELECT
    TO_CHAR(full_date, 'YYYYMMDD')::INT          AS date_key,
    full_date,
    EXTRACT(DAY     FROM full_date)::INT          AS day,
    EXTRACT(MONTH   FROM full_date)::INT          AS month,
    EXTRACT(QUARTER FROM full_date)::INT          AS quarter,
    EXTRACT(YEAR    FROM full_date)::INT          AS year,
    EXTRACT(WEEK    FROM full_date)::INT          AS week_of_year,
    TO_CHAR(full_date, 'Day')                     AS day_name,
    TO_CHAR(full_date, 'Month')                   AS month_name,
    EXTRACT(DOW FROM full_date) IN (0, 6)         AS is_weekend
FROM date_spine
  );
  
