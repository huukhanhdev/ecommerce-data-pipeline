[0m21:30:43.169341 [debug] [Thread-4  ]: On model.ecommerce_dbt.rpt_product_performance: /* {"app": "dbt", "dbt_version": "1.7.9", "profile_name": "ecommerce_dbt", "target_name": "dev", "node_id": "model.ecommerce_dbt.rpt_product_performance"} */

  
    

  create  table "ecommerce_olap"."staging_analytics"."rpt_product_performance__dbt_tmp"
  
  
    as
  
  (
    -- rpt_product_performance.sql
-- Product sales performance with cumulative revenue and ranking



WITH product_sales AS (
    SELECT
        f.product_key,
        p.name                                    AS product_name,
        p.category_name,
        p.seller_id,

        COUNT(DISTINCT f.order_id)                AS total_orders,
        SUM(f.quantity)                           AS total_units_sold,
        SUM(f.total_amount)                       AS total_revenue,
        AVG(f.unit_price)                         AS avg_selling_price,
        p.base_price,
        AVG(f.unit_price) - p.base_price          AS avg_discount_amount,
        COUNT(CASE WHEN f.status = 'returned' THEN 1 END) AS returns
    FROM "ecommerce_olap"."staging_analytics"."fact_orders"   f
    JOIN "ecommerce_olap"."staging_analytics"."dim_products"  p ON f.product_key = p.product_key
    WHERE f.status != 'cancelled'
    GROUP BY
        f.product_key, p.name, p.category_name, p.seller_id, p.base_price
)
SELECT
    *,
    -- Rank product within its category by revenue
    RANK() OVER (
        PARTITION BY category_name
        ORDER BY total_revenue DESC
    )                                             AS revenue_rank_in_category,

    -- Cumulative revenue within category (sorted by revenue desc)
    SUM(total_revenue) OVER (
        PARTITION BY category_name
        ORDER BY total_revenue DESC
        ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
    )                                             AS cumulative_revenue_in_category,

    ROUND(returns * 100.0 / NULLIF(total_orders, 0), 2) AS return_rate_pct
FROM product_sales
ORDER BY total_revenue DESC
  );
  
