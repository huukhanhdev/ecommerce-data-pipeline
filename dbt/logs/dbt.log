    avg(gross_revenue) OVER (
        PARTITION BY category_name
        ORDER BY full_date
        ROWS BETWEEN 6 PRECEDING AND CURRENT ROW
    ) AS revenue_7d_rolling_avg,
    rank() OVER (
        PARTITION BY year, week_of_year
        ORDER BY gross_revenue DESC
    ) AS daily_rank_in_week
FROM daily_rev
